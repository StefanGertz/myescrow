// Prisma schema for MyEscrow Postgres backend

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String                   @id
  name                String
  email               String                   @unique
  passwordHash        String
  emailVerified       Boolean                  @default(false)
  walletBalanceCents  Int                      @default(0)
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  escrows             Escrow[]                 @relation("EscrowOwner")
  buyerEscrows        Escrow[]                 @relation("EscrowBuyer")
  sellerEscrows       Escrow[]                 @relation("EscrowSeller")
  disputes            Dispute[]
  notifications       Notification[]
  timelineEvents      TimelineEvent[]
  walletTransactions  WalletTransaction[]
  verificationTokens  EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]
}

model Escrow {
  id                           Int               @id @default(autoincrement())
  reference                    String            @unique
  ownerId                      String
  owner                        User              @relation("EscrowOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  buyerId                      String?
  buyer                        User?             @relation("EscrowBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId                     String?
  seller                       User?             @relation("EscrowSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  creatorRole                  String
  counterpartyEmail            String
  title                        String
  counterpart                  String
  amountCents                  Int
  stage                        String
  dueDescription               String
  status                       String
  counterpartyApproved         Boolean           @default(false)
  lifecycleStatus              String            @default("pending_approval")
  fundingStatus                String            @default("not_funded")
  category                     String?
  description                  String?
  approvedAt                   DateTime?
  creatorSignatureDataUrl      String?           @db.Text
  counterpartySignatureDataUrl String?           @db.Text
  fundedAt                     DateTime?
  rejectedAt                   DateTime?
  cancelledAt                  DateTime?
  createdAt                    DateTime          @default(now())
  updatedAt                    DateTime          @updatedAt
  milestones                   EscrowMilestone[]

  @@index([ownerId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([lifecycleStatus])
  @@index([counterpartyEmail])
}

model EscrowMilestone {
  id          Int       @id @default(autoincrement())
  escrowId    Int
  escrow      Escrow    @relation(fields: [escrowId], references: [id], onDelete: Cascade)
  title       String
  description String?
  amountCents Int
  orderIndex  Int
  status      String    @default("pending")
  releasedAt  DateTime?
  rejectedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([escrowId, orderIndex])
}

model Dispute {
  id                Int      @id @default(autoincrement())
  reference         String   @unique
  ownerId           String
  owner             User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title             String
  ownerTeam         String
  amountCents       Int
  updatedLabel      String
  priority          String
  status            String
  workspaceLaunched Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Notification {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String
  detail    String
  meta      String
  txId      Int?
  createdAt DateTime @default(now())
}

model TimelineEvent {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  meta      String
  timeLabel String
  status    String
  createdAt DateTime @default(now())
}

model WalletTransaction {
  id          Int      @id @default(autoincrement())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountCents Int
  type        String
  createdAt   DateTime @default(now())
}

model Sequence {
  id           String @id
  currentValue Int    @default(0)
}

model EmailVerificationToken {
  id         Int       @id @default(autoincrement())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id         Int       @id @default(autoincrement())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}
