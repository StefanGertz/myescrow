// Prisma schema for MyEscrow Postgres backend

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                           String                      @id
  name                         String
  email                        String                      @unique
  passwordHash                 String
  emailVerified                Boolean                     @default(false)
  walletBalanceCents           Int                         @default(0)
  role                         String                      @default("customer")
  createdAt                    DateTime                    @default(now())
  updatedAt                    DateTime                    @updatedAt
  escrows                      Escrow[]                    @relation("EscrowOwner")
  buyerEscrows                 Escrow[]                    @relation("EscrowBuyer")
  sellerEscrows                Escrow[]                    @relation("EscrowSeller")
  disputes                     Dispute[]                   @relation("DisputeLegacyOwner")
  disputesOpened               Dispute[]                   @relation("DisputeOpenedBy")
  disputeResolutionsProposed   Dispute[]                   @relation("DisputeResolutionProposer")
  disputeArbitrationsRequested Dispute[]                   @relation("DisputeArbitrationRequester")
  disputeEvidenceSubmissions   DisputeEvidenceSubmission[]
  cancellationRequestsMade     CancellationRequest[]       @relation("CancellationRequestedBy")
  cancellationRequestsAnswered CancellationRequest[]       @relation("CancellationRespondedBy")
  notifications                Notification[]
  timelineEvents               TimelineEvent[]
  walletTransactions           WalletTransaction[]
  escrowLedgerEntries          EscrowLedgerEntry[]         @relation("LedgerActor")
  idempotencyRecords           IdempotencyRecord[]
  agreementVersionsCreated     AgreementVersion[]          @relation("AgreementVersionCreator")
  agreementSignatures          AgreementSignature[]
  milestoneSubmissions         MilestoneSubmission[]
  milestoneReviews             MilestoneReview[]
  verificationTokens           EmailVerificationToken[]
  passwordResetTokens          PasswordResetToken[]
  businessProfile              BusinessProfile?
  auditEvents                  AuditEvent[]                @relation("AuditActor")
}

model BusinessProfile {
  id                  Int      @id @default(autoincrement())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  legalName           String
  registrationCountry String
  registrationNumber  String
  registeredAddress   String
  representativeTitle String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Escrow {
  id                           Int                   @id @default(autoincrement())
  reference                    String                @unique
  ownerId                      String
  owner                        User                  @relation("EscrowOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  buyerId                      String?
  buyer                        User?                 @relation("EscrowBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId                     String?
  seller                       User?                 @relation("EscrowSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  creatorRole                  String
  counterpartyEmail            String
  title                        String
  counterpart                  String
  amountCents                  Int
  stage                        String
  dueDescription               String
  status                       String
  counterpartyApproved         Boolean               @default(false)
  lifecycleStatus              String                @default("pending_approval")
  fundingStatus                String                @default("not_funded")
  category                     String?
  description                  String?
  approvedAt                   DateTime?
  creatorSignatureDataUrl      String?               @db.Text
  counterpartySignatureDataUrl String?               @db.Text
  creatorPartySnapshot         Json                  @default("{}")
  counterpartyPartySnapshot    Json?
  fundedAt                     DateTime?
  rejectedAt                   DateTime?
  cancelledAt                  DateTime?
  createdAt                    DateTime              @default(now())
  updatedAt                    DateTime              @updatedAt
  milestones                   EscrowMilestone[]
  ledgerEntries                EscrowLedgerEntry[]
  agreementVersions            AgreementVersion[]    @relation("EscrowAgreementVersions")
  currentAgreementVersionId    Int?                  @unique
  currentAgreementVersion      AgreementVersion?     @relation("CurrentAgreementVersion", fields: [currentAgreementVersionId], references: [id], onDelete: Restrict)
  invitationDeliveries         InvitationDelivery[]
  invitationExpiresAt          DateTime?
  agreementResponseDueAt       DateTime?
  disputes                     Dispute[]
  cancellationRequests         CancellationRequest[]
  auditEvents                  AuditEvent[]

  @@index([ownerId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([lifecycleStatus])
  @@index([counterpartyEmail])
}

model EscrowMilestone {
  id                   Int                   @id @default(autoincrement())
  escrowId             Int
  escrow               Escrow                @relation(fields: [escrowId], references: [id], onDelete: Cascade)
  title                String
  description          String?
  amountCents          Int
  deadline             DateTime?
  orderIndex           Int
  status               String                @default("not_started")
  requestedTitle       String?
  requestedDescription String?
  requestedAmountCents Int?
  requestedDeadline    DateTime?
  changeRequestNote    String?
  changeRequestedAt    DateTime?
  releasedAt           DateTime?
  rejectedAt           DateTime?
  reviewDeadline       DateTime?
  reminderAt           DateTime?
  reminderSentAt       DateTime?
  reviewOverdueAt      DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  ledgerEntries        EscrowLedgerEntry[]
  submissions          MilestoneSubmission[]
  disputes             Dispute[]

  @@index([escrowId, orderIndex])
  @@index([status, reviewDeadline])
}

model MilestoneSubmission {
  id               Int                          @id @default(autoincrement())
  milestoneId      Int
  milestone        EscrowMilestone              @relation(fields: [milestoneId], references: [id], onDelete: Restrict)
  submitterId      String
  submitter        User                         @relation(fields: [submitterId], references: [id], onDelete: Restrict)
  submissionNumber Int
  note             String?
  submittedAt      DateTime                     @default(now())
  reviewDeadline   DateTime
  reminderAt       DateTime
  evidence         MilestoneEvidenceReference[]
  review           MilestoneReview?

  @@unique([milestoneId, submissionNumber])
  @@index([submitterId])
}

model MilestoneEvidenceReference {
  id           Int                 @id @default(autoincrement())
  submissionId Int
  submission   MilestoneSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  objectKey    String
  fileName     String
  contentType  String
  sizeBytes    Int
  sha256       String
  createdAt    DateTime            @default(now())

  @@index([submissionId])
}

model MilestoneReview {
  id           Int                 @id @default(autoincrement())
  submissionId Int                 @unique
  submission   MilestoneSubmission @relation(fields: [submissionId], references: [id], onDelete: Restrict)
  reviewerId   String
  reviewer     User                @relation(fields: [reviewerId], references: [id], onDelete: Restrict)
  decision     String
  reason       String?
  reviewedAt   DateTime            @default(now())

  @@index([reviewerId])
}

model Dispute {
  id                     Int                           @id @default(autoincrement())
  reference              String                        @unique
  ownerId                String
  owner                  User                          @relation("DisputeLegacyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  escrowId               Int?
  escrow                 Escrow?                       @relation(fields: [escrowId], references: [id], onDelete: Restrict)
  milestoneId            Int?
  milestone              EscrowMilestone?              @relation(fields: [milestoneId], references: [id], onDelete: Restrict)
  openedById             String?
  openedBy               User?                         @relation("DisputeOpenedBy", fields: [openedById], references: [id], onDelete: Restrict)
  title                  String
  ownerTeam              String
  amountCents            Int
  amountFrozenCents      Int                           @default(0)
  reason                 String?
  evidenceWindowEndsAt   DateTime?
  evidenceReminderSentAt DateTime?
  evidenceEscalatedAt    DateTime?
  resolutionAuthority    String                        @default("mutual_party_agreement")
  arbitrationRequestedAt DateTime?
  arbitrationRequestedById String?
  arbitrationRequestedBy User?                         @relation("DisputeArbitrationRequester", fields: [arbitrationRequestedById], references: [id], onDelete: Restrict)
  resolutionProposedById String?
  resolutionProposedBy   User?                         @relation("DisputeResolutionProposer", fields: [resolutionProposedById], references: [id], onDelete: Restrict)
  proposedSellerCents    Int?
  proposedBuyerCents     Int?
  resolutionNote         String?
  resolvedAt             DateTime?
  updatedLabel           String
  priority               String
  status                 String
  workspaceLaunched      Boolean                       @default(false)
  createdAt              DateTime                      @default(now())
  updatedAt              DateTime                      @updatedAt
  evidenceSubmissions    DisputeEvidenceSubmission[]
  allocations            DisputeResolutionAllocation[]

  @@index([escrowId, status])
  @@index([milestoneId, status])
  @@index([openedById])
}

model DisputeEvidenceSubmission {
  id          Int      @id @default(autoincrement())
  disputeId   Int
  dispute     Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  submitterId String
  submitter   User     @relation(fields: [submitterId], references: [id], onDelete: Restrict)
  note        String?
  evidence    Json     @default("[]")
  submittedAt DateTime @default(now())

  @@index([disputeId, submittedAt])
  @@index([submitterId])
}

model DisputeResolutionAllocation {
  id            Int               @id @default(autoincrement())
  disputeId     Int
  dispute       Dispute           @relation(fields: [disputeId], references: [id], onDelete: Restrict)
  recipient     String
  amountCents   Int
  ledgerEntryId Int               @unique
  ledgerEntry   EscrowLedgerEntry @relation(fields: [ledgerEntryId], references: [id], onDelete: Restrict)
  createdAt     DateTime          @default(now())

  @@index([disputeId])
}

model CancellationRequest {
  id                  Int                @id @default(autoincrement())
  reference           String             @unique
  escrowId            Int
  escrow              Escrow             @relation(fields: [escrowId], references: [id], onDelete: Restrict)
  requestedById       String
  requestedBy         User               @relation("CancellationRequestedBy", fields: [requestedById], references: [id], onDelete: Restrict)
  respondedById       String?
  respondedBy         User?              @relation("CancellationRespondedBy", fields: [respondedById], references: [id], onDelete: Restrict)
  mode                String
  reason              String
  status              String
  refundAmountCents   Int                @default(0)
  refundLedgerEntryId Int?               @unique
  refundLedgerEntry   EscrowLedgerEntry? @relation(fields: [refundLedgerEntryId], references: [id], onDelete: Restrict)
  requestedAt         DateTime           @default(now())
  respondedAt         DateTime?
  escalatedAt         DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([escrowId, status])
  @@index([requestedById])
}

model Notification {
  id          String    @id
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  label       String
  detail      String
  meta        String
  txId        Int?
  createdAt   DateTime  @default(now())
  dismissedAt DateTime?
}

model TimelineEvent {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  meta      String
  timeLabel String
  status    String
  createdAt DateTime @default(now())
}

model WalletTransaction {
  id          Int                @id @default(autoincrement())
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountCents Int
  type        String
  createdAt   DateTime           @default(now())
  ledgerEntry EscrowLedgerEntry?
}

model EscrowLedgerEntry {
  id                  Int                          @id @default(autoincrement())
  escrowId            Int
  escrow              Escrow                       @relation(fields: [escrowId], references: [id], onDelete: Restrict)
  milestoneId         Int?
  milestone           EscrowMilestone?             @relation(fields: [milestoneId], references: [id], onDelete: Restrict)
  movementType        String
  amountCents         Int
  currency            String                       @default("USD")
  idempotencyKey      String
  businessReference   String                       @unique
  actorId             String
  actor               User                         @relation("LedgerActor", fields: [actorId], references: [id], onDelete: Restrict)
  sourceCommand       String
  paymentProviderRef  String?
  walletTransactionId Int?                         @unique
  walletTransaction   WalletTransaction?           @relation(fields: [walletTransactionId], references: [id], onDelete: Restrict)
  disputeAllocation   DisputeResolutionAllocation?
  cancellationRefund  CancellationRequest?
  createdAt           DateTime                     @default(now())

  @@unique([escrowId, idempotencyKey])
  @@index([escrowId, createdAt])
  @@index([milestoneId])
  @@index([actorId])
}

model IdempotencyRecord {
  id             Int       @id @default(autoincrement())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  key            String
  command        String
  requestHash    String
  responseJson   Json?
  replayCount    Int       @default(0)
  lastReplayedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([userId, key])
  @@index([createdAt])
}

model OperationalJob {
  id           Int       @id @default(autoincrement())
  jobType      String
  dedupeKey    String    @unique
  payload      Json      @default("{}")
  status       String    @default("pending")
  attemptCount Int       @default(0)
  maxAttempts  Int       @default(5)
  runAt        DateTime
  lockedAt     DateTime?
  lastError    String?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status, runAt])
}

model OperationalWorkerState {
  id              String    @id
  lastStartedAt   DateTime?
  lastCompletedAt DateTime?
  lastSuccessAt   DateTime?
  lastError       String?
  updatedAt       DateTime  @updatedAt
}

model ReconciliationRun {
  id             Int       @id @default(autoincrement())
  status         String
  checkedEscrows Int       @default(0)
  exceptionCount Int       @default(0)
  report         Json      @default("{}")
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  alertedAt      DateTime?

  @@index([startedAt])
  @@index([status, startedAt])
}

model AuditEvent {
  id         Int      @id @default(autoincrement())
  dedupeKey  String?  @unique
  escrowId   Int?
  escrow     Escrow?  @relation(fields: [escrowId], references: [id], onDelete: Restrict)
  actorId    String?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: Restrict)
  actorType  String
  action     String
  entityType String
  entityId   String
  outcome    String
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([escrowId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
}

model AgreementVersion {
  id                Int                  @id @default(autoincrement())
  escrowId          Int
  escrow            Escrow               @relation("EscrowAgreementVersions", fields: [escrowId], references: [id], onDelete: Restrict)
  currentForEscrow  Escrow?              @relation("CurrentAgreementVersion")
  versionNumber     Int
  termsHash         String
  title             String
  description       String?
  amountCents       Int
  currency          String               @default("USD")
  creatorRole       String
  creatorParty      Json
  counterpartyParty Json?
  milestones        Json
  status            String               @default("current")
  createdById       String
  createdBy         User                 @relation("AgreementVersionCreator", fields: [createdById], references: [id], onDelete: Restrict)
  lockedAt          DateTime?
  createdAt         DateTime             @default(now())
  signatures        AgreementSignature[]

  @@unique([escrowId, versionNumber])
  @@index([escrowId, status])
  @@index([createdById])
}

model AgreementSignature {
  id                 Int              @id @default(autoincrement())
  agreementVersionId Int
  agreementVersion   AgreementVersion @relation(fields: [agreementVersionId], references: [id], onDelete: Restrict)
  signerId           String
  signer             User             @relation(fields: [signerId], references: [id], onDelete: Restrict)
  signerRole         String
  signatureDataUrl   String           @db.Text
  evidenceHash       String
  signedAt           DateTime         @default(now())

  @@unique([agreementVersionId, signerId])
  @@index([signerId])
}

model InvitationDelivery {
  id            Int           @id @default(autoincrement())
  escrowId      Int
  escrow        Escrow        @relation(fields: [escrowId], references: [id], onDelete: Restrict)
  recipient     String
  status        String        @default("queued")
  attemptCount  Int           @default(0)
  providerId    String?
  nextAttemptAt DateTime?
  failureReason String?
  expiresAt     DateTime
  responseDueAt DateTime
  acceptedAt    DateTime?
  supersededAt  DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  outboxEvents  OutboxEvent[]

  @@index([escrowId, createdAt])
  @@index([status, nextAttemptAt])
  @@index([recipient])
}

model OutboxEvent {
  id                   Int                @id @default(autoincrement())
  invitationDeliveryId Int
  invitationDelivery   InvitationDelivery @relation(fields: [invitationDeliveryId], references: [id], onDelete: Restrict)
  eventType            String
  payload              Json
  status               String             @default("pending")
  attemptCount         Int                @default(0)
  nextAttemptAt        DateTime           @default(now())
  lastError            String?
  providerId           String?
  processedAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([status, nextAttemptAt])
  @@index([invitationDeliveryId])
}

model Sequence {
  id           String @id
  currentValue Int    @default(0)
}

model EmailVerificationToken {
  id         Int       @id @default(autoincrement())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id         Int       @id @default(autoincrement())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}
